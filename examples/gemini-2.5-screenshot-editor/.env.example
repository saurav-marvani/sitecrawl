# Sitecrawl + Gemini Screenshot Editor Configuration
# Copy this file to .env and fill in your API keys

# Sitecrawl API Key - Get yours at https://sitecrawl.dev
SITECRAWL_API_KEY=your_sitecrawl_api_key_here

# Google Gemini API Key - Get yours at https://aistudio.google.com/
GEMINI_API_KEY=your_google_gemini_api_key_here

# Optional: Custom Sitecrawl API URL (for self-hosted instances)
# SITECRAWL_API_URL=https://your-sitecrawl-instance.com